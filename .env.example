# Local MusicXML import works without environment variables.

# Free PDF OMR connector.
# Deploy omr-worker/ and point this at that service. The worker runs Audiveris,
# an open-source OMR engine that exports MusicXML/MXL; this app converts that
# MusicXML into MIDI.
OMR_WORKER_URL=
OMR_WORKER_TOKEN=
PDF_UPLOAD_MAX_BYTES=83886080
PDF_TRANSCRIBES_PER_HOUR=8

# Free open-source audio connector.
# Deploy audio-worker/ and point this at that service. The production default
# uses Basic Pitch for lower latency. Transkun requires a custom worker image
# with PyTorch installed and is intentionally not part of the default public
# worker while its dependency stack has active advisories.
AUDIO_TRANSCRIPTION_WORKER_URL=
AUDIO_TRANSCRIPTION_WORKER_TOKEN=
AUDIO_ENGINE_MODE=basic-pitch
BASIC_PITCH_MODE=fallback
AUDIO_JOB_STARTS_PER_HOUR=6
AUDIO_JOB_POLLS_PER_WINDOW=180

# Shared public song/MIDI library. Created with `vercel blob create-store ... --yes`.
BLOB_READ_WRITE_TOKEN=
SONG_POSTS_PER_HOUR=24
SONG_POST_MAX_BYTES=31457280
MIDI_MAX_BYTES=10485760
SCORE_MAX_BYTES=20971520
